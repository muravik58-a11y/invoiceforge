generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum VatType {
  STANDARD
  REDUCED
  ZERO
  EXEMPT
  REVERSE_CHARGE
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  CASH
  CHEQUE
  STRIPE
  OTHER
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

// ─────────────────────────────────────────────
// ORGANIZATION
// ─────────────────────────────────────────────

model Organization {
  id            String  @id @default(cuid())
  clerkOrgId    String  @unique
  name          String
  slug          String  @unique

  // Company details
  companyName   String?
  companyNumber String?
  vatNumber     String?
  logo          String?
  brandColor         String? @default("#2563EB")
  preferredTemplate  String  @default("modern")

  // Registered address
  addressLine1  String?
  addressLine2  String?
  city          String?
  county        String?
  postcode      String?
  country       String? @default("United Kingdom")

  // Banking details
  bankName      String?
  bankSortCode  String?
  bankAccountNumber String?
  bankIban      String?
  bankSwift     String?
  paymentReference String?

  // Invoice settings
  invoicePrefix        String  @default("INV")
  invoiceCounter       Int     @default(0)
  defaultPaymentTerms  Int     @default(30)
  emailSignature       String?
  invoiceFooter        String?
  latePaymentNote      String?

  // Stripe / subscription
  stripeCustomerId   String?  @unique
  subscriptionId     String?  @unique
  subscriptionStatus String?
  planId             SubscriptionPlan @default(FREE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clients          Client[]
  products         Product[]
  invoices         Invoice[]
  payments         Payment[]
  recurringInvoices RecurringInvoice[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  apiKeys          ApiKey[]

  @@index([clerkOrgId])
  @@index([slug])
}

// ─────────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────────

model Client {
  id             String @id @default(cuid())
  organizationId String

  companyName    String
  contactName    String?
  email          String?
  phone          String?
  vatNumber      String?

  // Address
  addressLine1   String?
  addressLine2   String?
  city           String?
  county         String?
  postcode       String?
  country        String? @default("United Kingdom")

  // Defaults
  defaultPaymentTerms Int?     @default(30)
  defaultTaxRate      Decimal? @db.Decimal(5, 2)
  currency            String   @default("GBP")
  notes               String?
  isActive            Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  recurringInvoices RecurringInvoice[]
  auditLogs    AuditLog[]

  @@index([organizationId])
  @@index([organizationId, email])
  @@index([organizationId, isActive])
}

// ─────────────────────────────────────────────
// PRODUCT / SERVICE
// ─────────────────────────────────────────────

model Product {
  id             String @id @default(cuid())
  organizationId String

  name        String
  description String?
  sku         String?

  // Pricing (ex-VAT)
  unitPrice   Decimal @db.Decimal(10, 2)
  vatRate     Decimal @db.Decimal(5, 2)  @default(20)
  vatType     VatType @default(STANDARD)
  unit        String? @default("unit")

  // Categorisation
  category    String?

  // Inventory (null = service / not tracked)
  stockLevel   Int?
  reorderPoint Int?

  isActive    Boolean @default(true)
  isService   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, sku])
}

// ─────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────

model Invoice {
  id             String @id @default(cuid())
  organizationId String
  clientId       String

  invoiceNumber  String
  issueDate      DateTime
  dueDate        DateTime

  // Financials (all amounts in pence-precision decimals)
  subtotal        Decimal @db.Decimal(12, 2) @default(0)
  discountAmount  Decimal @db.Decimal(12, 2) @default(0)
  discountPercent Decimal @db.Decimal(5, 2)  @default(0)
  vatAmount       Decimal @db.Decimal(12, 2) @default(0)
  total           Decimal @db.Decimal(12, 2) @default(0)
  amountPaid      Decimal @db.Decimal(12, 2) @default(0)

  status InvoiceStatus @default(DRAFT)

  // Content
  notes     String?
  terms     String?
  templateId String?
  poNumber   String?
  reference  String?

  // Stripe payment link
  stripePaymentLinkId  String?
  stripePaymentLinkUrl String?

  // Delivery tracking
  sentAt          DateTime?
  lastReminderAt  DateTime?
  reminderCount   Int       @default(0)
  pdfUrl          String?

  // Recurring parent
  recurringInvoiceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client            @relation(fields: [clientId], references: [id])
  recurringInvoice RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id])
  items            InvoiceItem[]
  vatBreakdowns    VatBreakdown[]
  payments         Payment[]
  auditLogs        AuditLog[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([clientId])
  @@index([organizationId, status])
  @@index([organizationId, issueDate])
  @@index([organizationId, dueDate])
  @@index([recurringInvoiceId])
}

// ─────────────────────────────────────────────
// INVOICE ITEM
// ─────────────────────────────────────────────

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  productId String?

  description    String
  quantity       Decimal @db.Decimal(10, 3)
  unitPrice      Decimal @db.Decimal(10, 2)
  vatRate        Decimal @db.Decimal(5, 2)
  vatType        VatType @default(STANDARD)
  vatAmount      Decimal @db.Decimal(12, 2) @default(0)
  lineTotal      Decimal @db.Decimal(12, 2)   // inc-VAT
  lineTotalExVat Decimal @db.Decimal(12, 2)   // ex-VAT
  unit           String? @default("unit")
  sortOrder      Int     @default(0)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// VAT BREAKDOWN (per invoice, per rate band)
// ─────────────────────────────────────────────

model VatBreakdown {
  id        String  @id @default(cuid())
  invoiceId String

  vatRate   Decimal @db.Decimal(5, 2)
  vatType   VatType
  netAmount Decimal @db.Decimal(12, 2)
  vatAmount Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id             String @id @default(cuid())
  organizationId String
  invoiceId      String

  amount          Decimal       @db.Decimal(12, 2)
  method          PaymentMethod @default(BANK_TRANSFER)
  reference       String?
  notes           String?
  paidAt          DateTime
  stripePaymentId String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])

  @@index([organizationId])
  @@index([invoiceId])
  @@index([organizationId, paidAt])
}

// ─────────────────────────────────────────────
// RECURRING INVOICE TEMPLATE
// ─────────────────────────────────────────────

model RecurringInvoice {
  id             String @id @default(cuid())
  organizationId String
  clientId       String

  frequency     RecurringFrequency
  nextIssueDate DateTime
  lastIssuedDate DateTime?
  isActive      Boolean @default(true)
  templateData  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id])
  invoices     Invoice[]

  @@index([organizationId])
  @@index([clientId])
  @@index([organizationId, isActive])
  @@index([nextIssueDate])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id             String @id @default(cuid())
  organizationId String

  userId     String
  userEmail  String
  action     String   // e.g. "invoice.created", "payment.recorded"
  entityType String   // e.g. "Invoice", "Client"
  entityId   String
  changes    Json?

  // Optional denormalised links for fast filtering
  invoiceId String?
  clientId  String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])
  client       Client?      @relation(fields: [clientId], references: [id])

  @@index([organizationId])
  @@index([organizationId, entityType])
  @@index([organizationId, userId])
  @@index([invoiceId])
  @@index([clientId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id             String @id @default(cuid())
  organizationId String

  userId  String?   // null = org-wide
  title   String
  message String
  type    NotificationType @default(INFO)
  isRead  Boolean          @default(false)
  link    String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, userId])
  @@index([organizationId, isRead])
}

// ─────────────────────────────────────────────
// API KEY
// ─────────────────────────────────────────────

model ApiKey {
  id             String @id @default(cuid())
  organizationId String

  name      String
  keyHash   String   @unique  // SHA-256 of the raw key
  keyPrefix String            // first 8 chars shown in UI
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, isActive])
}

// ─────────────────────────────────────────────
// SITE CONFIG (singleton, id = "default")
// ─────────────────────────────────────────────

model SiteConfig {
  id                   String   @id @default("default")

  // Landing page copy
  heroHeadline         String   @default("Simple, compliant invoicing + inventory for UK businesses")
  heroSubheadline      String   @default("Send professional, VAT-compliant invoices in minutes. Manage stock, chase late payers, and export HMRC-ready reports — all in one place built for the UK market.")

  // Footer
  footerText           String?  // Extra text shown in footer (e.g. company details)
  footerLinks          Json?    // JSON array of { label, href } for footer link columns

  // App controls
  maintenanceMode      Boolean  @default(false)
  newSignupsEnabled    Boolean  @default(true)

  // Per-plan limits (JSON mirrors PlanLimits shape in lib/constants.ts)
  planLimitsFree       Json
  planLimitsPro        Json
  planLimitsEnterprise Json

  // Per-plan pricing in pence (JSON: { FREE: 0, PRO: 1200, ENTERPRISE: 4900 })
  // null = not yet synced; admin can override manually
  planPrices           Json?

  updatedAt            DateTime @updatedAt

  // Relations
  legalPages           LegalPage[]
}

// ─────────────────────────────────────────────
// LEGAL PAGES (Terms, Privacy, Cookies, GDPR)
// ─────────────────────────────────────────────

model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique  // e.g. "terms", "privacy", "cookies", "gdpr"
  title     String              // e.g. "Terms of Service"
  content   String              // HTML content of the page
  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteConfig SiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)
  siteConfigId String   @default("default")
}
